{
  "name": "clircel",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run dev:web",
    "dev:web": "bun run --cwd apps/web dev",
    "dev:api": "bun run --cwd apps/api dev",
    "build": "bun run build:web && bun run build:api && bun run build:cli",
    "build:web": "bun run --cwd apps/web build",
    "build:api": "bun run --cwd apps/api build",
    "build:cli": "bun run --cwd apps/cli build",
    "lint": "bun run lint:web && bun run lint:api && bun run lint:cli",
    "lint:web": "bun run --cwd apps/web lint",
    "lint:api": "bun run --cwd apps/api lint",
    "lint:cli": "bun run --cwd apps/cli lint",
    "cli": "bun run --cwd apps/cli start",
    "db:generate": "drizzle-kit generate --config=drizzle.config.ts",
    "db:migrate": "drizzle-kit push --config=drizzle.config.ts"
  }
}
