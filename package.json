{
  "name": "clircel",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run dev:web",
    "dev:web": "bun run --cwd apps/web dev",
    "dev:api": "bun run --cwd apps/api dev",
    "build": "bun run build:web && bun run build:api",
    "build:web": "bun run --cwd apps/web build",
    "build:api": "bun run --cwd apps/api build",
    "lint": "bun run lint:web && bun run lint:api",
    "lint:web": "bun run --cwd apps/web lint",
    "lint:api": "bun run --cwd apps/api lint",
    "db:generate": "bun run --cwd packages/db --env-file ../../apps/api/.env generate",
    "db:migrate": "bun run --cwd packages/db --env-file ../../apps/api/.env migrate"
  }
}
